rules_version = '2';

// Reglas de seguridad para la colección de invitados.
//
// Modelo de acceso:
//  - GET  (un documento por su id): PÚBLICO. El invitado entra por su enlace
//    (?id=...) y necesita leer SU documento para ver la invitación personalizada.
//  - LIST (consultar/listar la colección entera): SOLO ADMIN autenticado.
//    Así nadie sin login puede descargarse la lista completa de invitados.
//  - UPDATE: PÚBLICO pero limitado a los campos del RSVP del propio documento
//    (no pueden alterar nombres, esPareja, etc.). Deben conocer el id.
//  - CREATE / DELETE: SOLO ADMIN autenticado (script de importación, panel).
//
// Súbelas con:  firebase deploy --only firestore:rules --project TU_PROJECT_ID
service cloud.firestore {
  match /databases/{database}/documents {

    match /invitados/{invitadoId} {

      // Leer UN invitado concreto (get): público — necesario para el enlace.
      allow get: if true;

      // Listar / consultar TODA la colección: solo administradores.
      allow list: if request.auth != null;

      // RSVP público: solo se permiten los campos del formulario, nada más.
      // (No pueden tocar nombres, esPareja, id…)
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'confirmado', 'nombreCompleto', 'asiste',
            'acompanante', 'nombreAcompanante',
            'autobus', 'ninos', 'alergias', 'respondidoEn'
          ])
        && request.resource.data.ninos is int
        && request.resource.data.ninos >= 0;

      // Crear / borrar invitados: solo administradores autenticados.
      allow create, delete: if request.auth != null;
    }
  }
}
