# ─────────────────────────────────────────────────────────────
# Credenciales de Firebase (cliente web).
# Copia este archivo a `.env.local` y rellena los valores reales.
# En Vercel: Project Settings → Environment Variables (mismos nombres).
#
# Los encuentras en: consola de Firebase → ⚙️ Configuración del proyecto
#   → "Tus apps" → SDK setup and configuration.
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Solo para el script scripts/importGuests.js (NO se usan en la web).
# Credenciales de un usuario admin creado en Firebase Authentication.
ADMIN_EMAIL=
ADMIN_PASSWORD=
